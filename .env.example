# Copy this to .env for local testing (never commit .env)
# Add these as GitHub Actions secrets in your repo:
# Settings → Secrets and variables → Actions → New repository secret

# Your LeetCode session cookie (from browser DevTools → Application → Cookies)
LEETCODE_SESSION=your_leetcode_session_cookie_here

# Your LeetCode CSRF token (same place as above, csrftoken cookie)
LEETCODE_CSRF=your_leetcode_csrf_token_here

# Gemini API key — free tier works fine (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
